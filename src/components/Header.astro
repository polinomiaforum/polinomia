---
const user = Astro.locals.user;
const isAdmin = !!Astro.locals.isAdmin;
const path = Astro.url.pathname;

const now = new Date();
const fmt = new Intl.DateTimeFormat('es', {
  weekday: 'long',
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
const edition = fmt.format(now);

const navItems: { href: string; label: string; active: boolean }[] = [
  { href: '/', label: 'Foro', active: path === '/' },
  { href: '/paises', label: 'Países', active: path.startsWith('/paises') || path.startsWith('/pais/') },
  { href: '/moderacion', label: 'Moderación', active: path.startsWith('/moderacion') },
  { href: '/reglas', label: 'Reglas', active: path === '/reglas' },
];
---
<header class="masthead">
  <div class="masthead__top">
    <span>Edición · {edition}</span>
    <span style="display:flex; gap:16px; align-items:center; flex-wrap:wrap;">
      <button type="button" data-palette-toggle aria-label="cambiar tono" class="masthead__theme">Cambiar tono</button>
      {user ? (
        <a href={`/u/${user.username}`}>{user.username}</a>
      ) : (
        <a href="/login">Iniciar sesión · Registrarse</a>
      )}
    </span>
  </div>
  <h1 class="masthead__wordmark">Polinomia</h1>
  <p class="masthead__tagline">Un foro de debate de política y economía, abierto a quienes lo practican en serio.</p>
  <nav class="masthead__nav">
    {navItems.map((it) => (
      <a href={it.href} class:list={[it.active && 'is-active']}>{it.label}</a>
    ))}
    {user && (
      <a href="/h/nuevo" class:list={[path === '/h/nuevo' && 'is-active']}>Abrir hilo</a>
    )}
    {isAdmin && (
      <a href="/moderacion/casos" class:list={[path === '/moderacion/casos' && 'is-active']} style="color: var(--accent)">Admin</a>
    )}
    {user && (
      <form method="post" action="/api/logout" style="display:inline;">
        <button type="submit" style="appearance:none; border:0; background:transparent; font: inherit; letter-spacing: inherit; text-transform: inherit; color: var(--ink-3); cursor: pointer; padding: 8px 0;">Salir</button>
      </form>
    )}
  </nav>
</header>
