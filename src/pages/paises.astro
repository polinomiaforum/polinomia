---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { db, schema } from '~/db';
import { eq, sql } from 'drizzle-orm';

const countries = await db.select({
  id: schema.countries.id,
  slug: schema.countries.slug,
  name: schema.countries.name,
  threadCount: sql<number>`count(${schema.threads.id})::int`,
})
  .from(schema.countries)
  .leftJoin(schema.threads, eq(schema.threads.countryId, schema.countries.id))
  .groupBy(schema.countries.id)
  .orderBy(schema.countries.sortOrder, schema.countries.name);
---
<BaseLayout title="Países">
  <div style="padding: 36px 0 60px;">
    <span class="kicker">Índice geográfico</span>
    <h1 style="font-family: var(--font-serif); font-weight: 400; font-size: 48px; line-height: 1.05; margin: 8px 0 32px; letter-spacing: -0.015em;">Países y regiones</h1>

    <ul style="display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 18px; list-style: none; padding: 0; margin: 0;">
      {countries.map((c) => (
        <li style="padding: 12px 0; border-bottom: 1px solid var(--rule);">
          <a href={`/pais/${c.slug}`} style="display: flex; justify-content: space-between; align-items: baseline; gap: 8px;">
            <span style="font-family: var(--font-serif); font-size: 18px;">{c.name}</span>
            <span class="meta-mono" style="color: var(--accent);">{c.threadCount}</span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</BaseLayout>
