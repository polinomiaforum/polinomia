---
import BaseLayout from '~/layouts/BaseLayout.astro';
const email = Astro.url.searchParams.get('email') ?? '';
---
<BaseLayout title="revisá tu mail">
  <div class="max-w-md mx-auto px-6 py-12">
    <p class="kicker mb-1">// auth · paso 2</p>
    <h1 class="text-3xl mb-4 prompt">revisá tu mail</h1>

    <div class="alert mb-4">
      te mandamos un link a <strong>{email}</strong>. hacé click ahí para entrar (o para crear tu cuenta si todavía no la tenés).
    </div>

    <ul class="text-sm space-y-2" style="color: var(--color-muted)">
      <li>// el link vence en <strong>15 minutos</strong>.</li>
      <li>// se usa una sola vez. si lo abrís otra vez, no funciona.</li>
      <li>// si no ves el mail, mirá la carpeta de spam.</li>
    </ul>

    <p class="mt-8 text-sm">
      <a href="/login" style="color: var(--color-accent)">← volver a login</a>
    </p>
  </div>
</BaseLayout>
