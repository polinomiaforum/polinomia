---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { db, schema } from '~/db';
import { desc } from 'drizzle-orm';
import { DECISIONS, RULES } from '~/lib/moderation';

const decLabel = new Map(DECISIONS.map((d) => [d.id, d.label] as const));
const ruleLabel = new Map(RULES.map((r) => [r.n, r.label] as const));

const entries = await db.select({
  id: schema.verdicts.id,
  decision: schema.verdicts.decision,
  rationale: schema.verdicts.rationale,
  ruleNumber: schema.verdicts.ruleNumber,
  createdAt: schema.verdicts.createdAt,
})
  .from(schema.verdicts)
  .orderBy(desc(schema.verdicts.createdAt))
  .limit(100);

const isAdmin = !!Astro.locals.isAdmin;
---
<BaseLayout title="bitácora de moderación">
  <div class="max-w-3xl mx-auto px-6 py-10">
    <p class="kicker mb-1">// moderación</p>
    <h1 class="text-3xl mb-2 prompt">bitácora pública</h1>
    <p class="text-sm mb-6" style="color: var(--color-muted)">
      cada decisión de moderación queda acá, anonimizada. el criterio es público;
      las identidades, no. <a href="/reglas" style="color: var(--color-accent)">ver código de conducta</a>.
      {isAdmin && (<>· <a href="/moderacion/casos" style="color: var(--color-accent)">→ casos pendientes</a></>)}
    </p>

    {entries.length === 0 ? (
      <p style="color: var(--color-muted)">todavía no hay decisiones publicadas.</p>
    ) : (
      <ul>
        {entries.map((v, i) => (
          <li class:list={['py-4', i > 0 && 'border-t rule-soft']}>
            <div class="flex flex-wrap items-center gap-2 mb-1 text-xs" style="color: var(--color-muted)">
              <span class="tag tag-accent">regla {v.ruleNumber}</span>
              <span class="tag">{decLabel.get(v.decision) ?? v.decision}</span>
              <span>· {v.createdAt.toLocaleDateString('es', { day: 'numeric', month: 'short', year: 'numeric' })}</span>
            </div>
            <p class="text-sm">
              <span style="color: var(--color-muted)">// {ruleLabel.get(v.ruleNumber)}.</span>
              {' '}{v.rationale}
            </p>
          </li>
        ))}
      </ul>
    )}
  </div>
</BaseLayout>
