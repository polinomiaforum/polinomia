---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { db, schema } from '~/db';
import { desc } from 'drizzle-orm';
import { DECISIONS, RULES } from '~/lib/moderation';

const decLabel = new Map(DECISIONS.map((d) => [d.id, d.label] as const));
const ruleLabel = new Map(RULES.map((r) => [r.n, r.label] as const));

const entries = await db.select({
  id: schema.verdicts.id,
  decision: schema.verdicts.decision,
  rationale: schema.verdicts.rationale,
  ruleNumber: schema.verdicts.ruleNumber,
  createdAt: schema.verdicts.createdAt,
})
  .from(schema.verdicts)
  .orderBy(desc(schema.verdicts.createdAt))
  .limit(100);

const isAdmin = !!Astro.locals.isAdmin;
---
<BaseLayout title="Bitácora de moderación">
  <article class="thread page-anim">
    <div class="thread__kicker">
      <span class="kicker">Moderación</span>
    </div>
    <h1 class="thread__title">Bitácora pública</h1>
    <p style="font-family: var(--font-serif); font-size: 20px; line-height: 1.5; color: var(--ink-2); margin: 0 0 28px; max-width: 60ch;">
      Cada decisión de moderación queda acá, anonimizada. El criterio es público; las identidades, no.
      <a href="/reglas" style="color: var(--accent);">Ver código de conducta</a>.
      {isAdmin && (<> · <a href="/moderacion/casos" style="color: var(--accent);">→ Casos pendientes</a></>)}
    </p>

    {entries.length === 0 ? (
      <p class="meta" style="padding: 32px 0;">Todavía no hay decisiones publicadas.</p>
    ) : (
      <div class="feed">
        {entries.map((v) => (
          <article class="feed-item">
            <div class="feed-item__head" style="grid-column: 1 / -1;">
              <span class="kicker">Regla {v.ruleNumber}</span>
              <span class="meta" style="color: var(--ink-3);">{decLabel.get(v.decision) ?? v.decision}</span>
              <span class="meta" style="margin-left: auto;">{v.createdAt.toLocaleDateString('es', { day: 'numeric', month: 'short', year: 'numeric' })}</span>
            </div>
            <div style="grid-column: 1 / -1;">
              <p style="font-family: var(--font-serif); font-size: 17px; line-height: 1.5; margin: 0;">
                <span class="meta" style="margin-right: 6px;">{ruleLabel.get(v.ruleNumber)}.</span>
                {v.rationale}
              </p>
            </div>
          </article>
        ))}
      </div>
    )}
  </article>
</BaseLayout>
