---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { db, schema } from '~/db';
import { desc, eq, and, gte, alias } from 'drizzle-orm';
import { DECISIONS, RULES } from '~/lib/moderation';
import { relativeTime, renderBody } from '~/lib/text';

if (!Astro.locals.isAdmin) return new Response('No autorizado', { status: 403 });

const idStr = Astro.params.id;
const id = idStr ? parseInt(idStr, 10) : NaN;
if (!Number.isFinite(id)) return new Response('No encontrado', { status: 404 });

const reporter = alias(schema.users, 'reporter');
const reported = alias(schema.users, 'reported');

const [report] = await db.select({
  id: schema.reports.id,
  status: schema.reports.status,
  ruleNumber: schema.reports.ruleNumber,
  context: schema.reports.context,
  createdAt: schema.reports.createdAt,
  postId: schema.reports.postId,
  threadId: schema.reports.threadId,
  threadTitle: schema.threads.title,
  postBody: schema.posts.body,
  postCreatedAt: schema.posts.createdAt,
  postHiddenAt: schema.posts.hiddenAt,
  reporterId: reporter.id,
  reporterUsername: reporter.username,
  reportedId: reported.id,
  reportedUsername: reported.username,
})
  .from(schema.reports)
  .innerJoin(schema.threads, eq(schema.threads.id, schema.reports.threadId))
  .innerJoin(schema.posts, eq(schema.posts.id, schema.reports.postId))
  .innerJoin(reporter, eq(reporter.id, schema.reports.reporterId))
  .innerJoin(reported, eq(reported.id, schema.reports.reportedUserId))
  .where(eq(schema.reports.id, id))
  .limit(1);

if (!report) return new Response('Caso no encontrado', { status: 404 });

const since90 = new Date(Date.now() - 90 * 86400_000);
const priorSanctions = await db.select()
  .from(schema.sanctions)
  .where(and(
    eq(schema.sanctions.userId, report.reportedId),
    gte(schema.sanctions.appliedAt, since90),
  ))
  .orderBy(desc(schema.sanctions.appliedAt));

const error = Astro.url.searchParams.get('error');
const ruleLabel = RULES.find((r) => r.n === report.ruleNumber)?.label;
---
<BaseLayout title={`Caso #${report.id}`}>
  <article class="thread page-anim">
    <div class="thread__kicker">
      <span class="kicker">Admin · Caso #{report.id}</span>
      <span class="reply__tag reply__tag--reformular">{report.status}</span>
      <span class="meta">abierto {relativeTime(report.createdAt)}</span>
    </div>
    <h1 class="thread__title">Regla {report.ruleNumber}: {ruleLabel}</h1>

    <header class="replies-h" style="margin-top: 24px;">
      <h3>Post reportado</h3>
    </header>
    <div class="card">
      <div class="meta" style="margin-bottom: 12px;">
        @{report.reportedUsername} en <a href={`/h/${report.threadId}#p${report.postId}`} style="color: var(--accent);">{report.threadTitle}</a>
        · {relativeTime(report.postCreatedAt)}
        {report.postHiddenAt && <span style="margin-left: 8px; color: var(--accent);">(ya oculto)</span>}
      </div>
      <div class="body-text" style="font-size: 16px;" set:html={renderBody(report.postBody)} />
    </div>

    <header class="replies-h" style="margin-top: 24px;">
      <h3>Contexto del reporte</h3>
    </header>
    <div class="card">
      <p class="meta" style="margin: 0 0 8px;">por @{report.reporterUsername}</p>
      <p style="font-family: var(--font-serif); font-size: 17px; margin: 0;">{report.context}</p>
    </div>

    <header class="replies-h" style="margin-top: 24px;">
      <h3>Expediente (últimos 90 días)</h3>
    </header>
    {priorSanctions.length === 0 ? (
      <p class="meta" style="padding: 12px 0;">Sin sanciones previas. Primer caso.</p>
    ) : (
      <ul style="list-style: none; padding: 0; margin: 0;">
        {priorSanctions.map((s) => (
          <li style="padding: 10px 0; border-bottom: 1px solid var(--rule);">
            <span class="reply__tag reply__tag--reformular">{s.type}</span>
            {s.ruleNumber && <span class="reply__tag" style="margin-left: 8px;">regla {s.ruleNumber}</span>}
            <span class="meta" style="margin-left: 12px;">{relativeTime(s.appliedAt)} · {s.reason}</span>
          </li>
        ))}
      </ul>
    )}

    {report.status === 'pending' ? (
      <>
        <header class="replies-h" style="margin-top: 36px;">
          <h3>Veredicto</h3>
        </header>
        {error && <div class="alert alert-error">Faltan campos: elegí una decisión y escribí una línea de justificación.</div>}
        <form method="post" action="/api/moderacion/decide" style="display: flex; flex-direction: column; gap: 20px;">
          <input type="hidden" name="reportId" value={report.id} />
          <input type="hidden" name="ruleNumber" value={report.ruleNumber} />

          <fieldset style="border: 0; padding: 0; margin: 0;">
            <legend class="kicker kicker--muted" style="margin-bottom: 12px;">Decisión</legend>
            <div style="display: flex; flex-direction: column; gap: 10px;">
              {DECISIONS.map((d) => (
                <label style="display: flex; align-items: flex-start; gap: 12px; font-family: var(--font-serif); font-size: 17px; cursor: pointer;">
                  <input type="radio" name="decision" value={d.id} required style="width: auto; margin-top: 6px;" />
                  <span>
                    <b>{d.label}</b>
                    <span class="meta" style="margin-left: 8px;">— {d.desc}</span>
                  </span>
                </label>
              ))}
            </div>
          </fieldset>

          <label>
            <span class="kicker kicker--muted" style="display: block; margin-bottom: 6px;">Justificación (una línea, va a la bitácora pública)</span>
            <input type="text" name="rationale" required minlength="10" maxlength="400"
              placeholder="ej: el post llama 'imbécil' al usuario, sin discutir su argumento." />
          </label>

          <div style="display: flex; justify-content: flex-end; padding-top: 12px; border-top: 1px solid var(--rule);">
            <button type="submit" class="btn">Aplicar veredicto</button>
          </div>
        </form>
      </>
    ) : (
      <div class="alert" style="margin-top: 24px;">
        Este caso ya fue resuelto. Veredicto: <b>{report.status}</b>.
        <a href="/moderacion" style="color: var(--accent); margin-left: 8px;">→ Ver bitácora</a>
      </div>
    )}
  </article>
</BaseLayout>
