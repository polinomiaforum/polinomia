---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { db, schema } from '~/db';
import { desc, eq, alias } from 'drizzle-orm';
import { relativeTime } from '~/lib/text';

if (!Astro.locals.isAdmin) return new Response('No autorizado', { status: 403 });

const reporter = alias(schema.users, 'reporter');
const reported = alias(schema.users, 'reported');

const pending = await db.select({
  id: schema.reports.id,
  ruleNumber: schema.reports.ruleNumber,
  context: schema.reports.context,
  createdAt: schema.reports.createdAt,
  postId: schema.reports.postId,
  threadId: schema.reports.threadId,
  threadTitle: schema.threads.title,
  reporterUsername: reporter.username,
  reportedUsername: reported.username,
})
  .from(schema.reports)
  .innerJoin(schema.threads, eq(schema.threads.id, schema.reports.threadId))
  .innerJoin(reporter, eq(reporter.id, schema.reports.reporterId))
  .innerJoin(reported, eq(reported.id, schema.reports.reportedUserId))
  .where(eq(schema.reports.status, 'pending'))
  .orderBy(desc(schema.reports.createdAt));
---
<BaseLayout title="Casos pendientes">
  <article class="thread page-anim" style="max-width: 900px;">
    <div class="thread__kicker">
      <span class="kicker">Admin · Moderación</span>
    </div>
    <h1 class="thread__title">Casos pendientes</h1>
    <p style="font-family: var(--font-serif); font-size: 20px; line-height: 1.5; color: var(--ink-2); margin: 0 0 32px; max-width: 60ch;">
      Modo fundador: vos sos el jurado. Cada decisión queda en la <a href="/moderacion" style="color: var(--accent);">bitácora pública</a> anonimizada.
    </p>

    {pending.length === 0 ? (
      <p class="meta" style="padding: 32px 0;">No hay reportes pendientes.</p>
    ) : (
      <div style="display: flex; flex-direction: column; gap: 20px;">
        {pending.map((r) => (
          <div class="card">
            <div style="display: flex; flex-wrap: wrap; align-items: center; gap: 12px; margin-bottom: 12px;">
              <span class="kicker">Regla {r.ruleNumber}</span>
              <span class="meta">{relativeTime(r.createdAt)}</span>
              <span class="meta">·</span>
              <span class="meta">en <a href={`/h/${r.threadId}`} style="color: var(--accent);">{r.threadTitle}</a></span>
            </div>
            <p style="font-family: var(--font-serif); font-size: 17px; margin: 0 0 8px;">
              <b>@{r.reporterUsername}</b> reportó a <b>@{r.reportedUsername}</b>
            </p>
            <p style="font-family: var(--font-serif); font-size: 16px; color: var(--ink-2); margin: 0 0 16px;">{r.context}</p>
            <a href={`/moderacion/caso/${r.id}`} class="btn">→ Revisar caso</a>
          </div>
        ))}
      </div>
    )}
  </article>
</BaseLayout>
