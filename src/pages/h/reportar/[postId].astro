---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { db, schema } from '~/db';
import { eq } from 'drizzle-orm';
import { RULES, canReport } from '~/lib/moderation';
import { renderBody } from '~/lib/text';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/login');
if (!canReport(user)) return Astro.redirect('/cuenta/sancionada?reportes=1');

const postIdStr = Astro.params.postId;
const postId = postIdStr ? parseInt(postIdStr, 10) : NaN;
if (!Number.isFinite(postId)) return new Response('No encontrado', { status: 404 });

const [post] = await db.select({
  id: schema.posts.id,
  body: schema.posts.body,
  threadId: schema.posts.threadId,
  authorUsername: schema.users.username,
  threadTitle: schema.threads.title,
})
  .from(schema.posts)
  .innerJoin(schema.users, eq(schema.users.id, schema.posts.authorId))
  .innerJoin(schema.threads, eq(schema.threads.id, schema.posts.threadId))
  .where(eq(schema.posts.id, postId))
  .limit(1);

if (!post) return new Response('Post no encontrado', { status: 404 });
if (post.authorUsername === user.username) {
  return Astro.redirect(`/h/${post.threadId}`);
}

const error = Astro.url.searchParams.get('error');
---
<BaseLayout title="Reportar post">
  <article class="thread page-anim">
    <div class="thread__kicker">
      <span class="kicker">Moderación</span>
    </div>
    <h1 class="thread__title">Reportar post</h1>
    <p style="font-family: var(--font-serif); font-size: 20px; line-height: 1.5; color: var(--ink-2); margin: 0 0 28px; max-width: 60ch;">
      El reporte va a un jurado humano que va a leer el post y tu contexto. Reportes mal fundamentados pueden hacer que pierdas el derecho a reportar por 30 días.
    </p>

    <div class="card" style="margin-bottom: 24px;">
      <div class="meta" style="margin-bottom: 8px;">
        En <a href={`/h/${post.threadId}`} style="color: var(--accent);">{post.threadTitle}</a> · por @{post.authorUsername}
      </div>
      <div class="body-text" style="font-size: 16px;" set:html={renderBody(post.body)} />
    </div>

    {error === 'short' && <div class="alert alert-error">El contexto debe tener al menos 20 caracteres.</div>}

    <form method="post" action="/api/reports" style="display: flex; flex-direction: column; gap: 20px;">
      <input type="hidden" name="postId" value={post.id} />

      <fieldset style="border: 0; padding: 0; margin: 0;">
        <legend class="kicker kicker--muted" style="margin-bottom: 12px;">Regla violada</legend>
        <div style="display: flex; flex-direction: column; gap: 10px;">
          {RULES.map((r) => (
            <label style="display: flex; align-items: flex-start; gap: 12px; font-family: var(--font-serif); font-size: 17px; cursor: pointer;">
              <input type="radio" name="ruleNumber" value={r.n} required style="width: auto; margin-top: 6px;" />
              <span>
                <b>{r.n}. {r.label}</b>
                <span class="meta" style="margin-left: 8px;">({r.short})</span>
              </span>
            </label>
          ))}
        </div>
      </fieldset>

      <label>
        <span class="kicker kicker--muted" style="display: block; margin-bottom: 6px;">Contexto (qué exactamente viola la regla y por qué)</span>
        <textarea name="context" required rows="4" minlength="20" maxlength="1000"
          placeholder="Ej: el post llama 'imbécil' a otro usuario en lugar de responder al argumento."></textarea>
      </label>

      <div style="display: flex; justify-content: space-between; align-items: center; padding-top: 12px; border-top: 1px solid var(--rule);">
        <a href={`/h/${post.threadId}`} class="meta" style="color: var(--ink-2);">← Cancelar</a>
        <button type="submit" class="btn">Enviar reporte</button>
      </div>
    </form>
  </article>
</BaseLayout>
