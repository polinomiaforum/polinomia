---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { db, schema } from '~/db';
import { eq } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/login');

const postIdStr = Astro.params.postId;
const postId = postIdStr ? parseInt(postIdStr, 10) : NaN;
if (!Number.isFinite(postId)) return new Response('No encontrado', { status: 404 });

const [post] = await db.select().from(schema.posts).where(eq(schema.posts.id, postId)).limit(1);
if (!post) return new Response('Post no encontrado', { status: 404 });
if (post.authorId !== user.id) return new Response('No autorizado', { status: 403 });

const mustReformulate = post.needsReformulation === 1;
const within1h = (Date.now() - post.createdAt.getTime()) < 3600_000;
if (!mustReformulate && !within1h) {
  return Astro.redirect(`/h/${post.threadId}?error=expired_edit`);
}

const error = Astro.url.searchParams.get('error');
---
<BaseLayout title="Editar post">
  <article class="thread page-anim">
    <div class="thread__kicker">
      <span class="kicker">Editar</span>
    </div>
    <h1 class="thread__title">{mustReformulate ? 'Reformular post' : 'Editar post'}</h1>

    {mustReformulate && (
      <div class="alert">
        Este post fue marcado por la moderación para ser reformulado.
        {post.reformulateDueAt && <> Tenés hasta <b>{post.reformulateDueAt.toLocaleString('es')}</b> para editarlo.</>}
        Al guardar, el post deja de estar oculto.
      </div>
    )}

    {error === 'short' && <div class="alert alert-error">El contenido debe tener al menos 30 caracteres.</div>}

    <form method="post" action="/api/posts/edit" style="display: flex; flex-direction: column; gap: 16px; margin-top: 24px;">
      <input type="hidden" name="postId" value={post.id} />
      <label>
        <span class="kicker kicker--muted" style="display: block; margin-bottom: 6px;">Contenido</span>
        <textarea name="body" required rows="12" minlength="30" style="min-height: 240px;">{post.body}</textarea>
      </label>
      <div style="display: flex; justify-content: space-between; align-items: center; padding-top: 12px; border-top: 1px solid var(--rule);">
        <a href={`/h/${post.threadId}`} class="meta" style="color: var(--ink-2);">← Cancelar</a>
        <button type="submit" class="btn">Guardar</button>
      </div>
    </form>
  </article>
</BaseLayout>
