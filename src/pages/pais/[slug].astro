---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Byline from '~/components/Byline.astro';
import { db, schema } from '~/db';
import { and, desc, eq } from 'drizzle-orm';
import { relativeTime } from '~/lib/text';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/paises');

const [country] = await db.select().from(schema.countries).where(eq(schema.countries.slug, slug)).limit(1);
if (!country) return new Response('País no encontrado', { status: 404 });

const topicFilter = Astro.url.searchParams.get('tema');

const threads = await db.select({
  id: schema.threads.id,
  title: schema.threads.title,
  lastActivityAt: schema.threads.lastActivityAt,
  topicSlug: schema.topics.slug,
  topicName: schema.topics.name,
  authorUsername: schema.users.username,
  authorDeclaredView: schema.users.declaredView,
  authorAvatarUrl: schema.users.avatarUrl,
})
  .from(schema.threads)
  .innerJoin(schema.topics, eq(schema.topics.id, schema.threads.topicId))
  .innerJoin(schema.users, eq(schema.users.id, schema.threads.authorId))
  .where(and(
    eq(schema.threads.countryId, country.id),
    topicFilter ? eq(schema.topics.slug, topicFilter) : undefined,
  ))
  .orderBy(desc(schema.threads.lastActivityAt));

const topics = await db.selectDistinct({
  slug: schema.topics.slug,
  name: schema.topics.name,
})
  .from(schema.threads)
  .innerJoin(schema.topics, eq(schema.topics.id, schema.threads.topicId))
  .where(eq(schema.threads.countryId, country.id))
  .orderBy(schema.topics.name);
---
<BaseLayout title={country.name}>
  <div style="padding: 24px 0 12px;">
    <span class="kicker"><a href="/paises" style="color: inherit;">Países</a> · {country.name}</span>
  </div>

  <h1 style="font-family: var(--font-serif); font-weight: 400; font-size: clamp(40px, 5vw, 56px); line-height: 1.05; margin: 8px 0 24px; letter-spacing: -0.018em;">
    {country.name}
  </h1>

  {topics.length > 0 && (
    <div class="substrip">
      <div class="substrip__cats">
        <a href={`/pais/${country.slug}`} class:list={[!topicFilter && 'is-active']}>Todos los temas</a>
        {topics.map((t) => (
          <a href={`/pais/${country.slug}?tema=${t.slug}`} class:list={[topicFilter === t.slug && 'is-active']}>{t.name}</a>
        ))}
      </div>
    </div>
  )}

  {threads.length === 0 ? (
    <p class="meta" style="padding: 60px 0; text-align: center;">
      Todavía no hay hilos en {country.name}. <a href="/h/nuevo" style="color: var(--accent);">Abrí el primero →</a>
    </p>
  ) : (
    <div class="feed">
      {threads.map((t) => (
        <article class="feed-item">
          <div class="feed-item__head" style="grid-column: 1 / -1;">
            <span class="kicker"><a href={`/tema/${t.topicSlug}`} style="color: inherit;">{t.topicName}</a></span>
            <span class="meta" style="margin-left: auto;">{relativeTime(t.lastActivityAt)}</span>
          </div>
          <h2 class="feed-item__title">
            <a href={`/h/${t.id}`}>{t.title}</a>
          </h2>
          <div class="feed-item__footer">
            <Byline username={t.authorUsername} declaredView={t.authorDeclaredView} avatarUrl={t.authorAvatarUrl} />
          </div>
        </article>
      ))}
    </div>
  )}
</BaseLayout>
