---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Byline from '~/components/Byline.astro';
import { db, schema } from '~/db';
import { desc, eq, sql } from 'drizzle-orm';
import { relativeTime } from '~/lib/text';

const { username } = Astro.params;
if (!username) return new Response('No encontrado', { status: 404 });

const [user] = await db.select({
  id: schema.users.id,
  username: schema.users.username,
  bio: schema.users.bio,
  declaredView: schema.users.declaredView,
  avatarUrl: schema.users.avatarUrl,
  createdAt: schema.users.createdAt,
})
  .from(schema.users)
  .where(eq(schema.users.username, username))
  .limit(1);

if (!user) return new Response('Usuario no encontrado', { status: 404 });

const threads = await db.select({
  id: schema.threads.id,
  title: schema.threads.title,
  lastActivityAt: schema.threads.lastActivityAt,
  topicSlug: schema.topics.slug,
  topicName: schema.topics.name,
  countrySlug: schema.countries.slug,
  countryName: schema.countries.name,
})
  .from(schema.threads)
  .innerJoin(schema.topics, eq(schema.topics.id, schema.threads.topicId))
  .innerJoin(schema.countries, eq(schema.countries.id, schema.threads.countryId))
  .where(eq(schema.threads.authorId, user.id))
  .orderBy(desc(schema.threads.lastActivityAt));

const [{ count: postCount }] = await db.select({ count: sql<number>`count(*)::int` })
  .from(schema.posts).where(eq(schema.posts.authorId, user.id));

const [{ count: sourceCount }] = await db.select({ count: sql<number>`count(*)::int` })
  .from(schema.sources)
  .innerJoin(schema.posts, eq(schema.posts.id, schema.sources.postId))
  .where(eq(schema.posts.authorId, user.id));

const isMe = Astro.locals.user?.id === user.id;
const updated = Astro.url.searchParams.get('saved') === '1';
const passkeyMsg = Astro.url.searchParams.get('passkey');

const userPasskeys = isMe
  ? await db.select().from(schema.passkeys).where(eq(schema.passkeys.userId, user.id)).orderBy(desc(schema.passkeys.createdAt))
  : [];
---
<BaseLayout title={`@${user.username}`}>
  <article class="thread page-anim" style="max-width: 800px;">
    <div class="thread__kicker">
      <span class="kicker">Perfil</span>
    </div>

    <div style="display: flex; align-items: center; gap: 18px; margin-bottom: 8px;">
      <Byline username={user.username} declaredView={user.declaredView} avatarUrl={user.avatarUrl} size="lg" />
    </div>

    <p class="meta" style="margin: 8px 0 4px;">
      Miembro desde {user.createdAt.toLocaleDateString('es', { month: 'long', year: 'numeric' })}
      &middot; <b style="color: var(--ink);">{threads.length}</b> hilos
      &middot; <b style="color: var(--ink);">{postCount}</b> respuestas
      &middot; <b style="color: var(--ink);">{sourceCount}</b> fuentes citadas
    </p>

    {user.bio && (
      <p style="font-family: var(--font-serif); font-size: 19px; line-height: 1.55; margin-top: 20px; color: var(--ink); max-width: 60ch;">
        {user.bio}
      </p>
    )}

    {isMe && (
      <>
        <details style="margin-top: 32px;" class="card">
          <summary style="cursor: pointer; font-family: var(--font-serif); font-style: italic; font-size: 18px;">Editar mi perfil</summary>
          {updated && <div class="alert alert-ok" style="margin-top: 16px;">Perfil actualizado.</div>}
          <form method="post" action="/api/profile" style="display: flex; flex-direction: column; gap: 12px; margin-top: 16px;">
            <label>
              <span class="kicker kicker--muted" style="display: block; margin-bottom: 6px;">Postura declarada</span>
              <input type="text" name="declaredView" value={user.declaredView ?? ''} placeholder="ej: economista, escuela austríaca" maxlength="100" />
            </label>
            <label>
              <span class="kicker kicker--muted" style="display: block; margin-bottom: 6px;">Bio</span>
              <textarea name="bio" rows="3" maxlength="500">{user.bio ?? ''}</textarea>
            </label>
            <button type="submit" class="btn" style="align-self: flex-start;">Guardar</button>
          </form>
        </details>

        <details style="margin-top: 16px;" class="card">
          <summary style="cursor: pointer; font-family: var(--font-serif); font-style: italic; font-size: 18px;">Passkeys ({userPasskeys.length})</summary>
          <p class="meta" style="margin: 12px 0; line-height: 1.6;">
            Las passkeys te dejan entrar con Face ID / Touch ID / YubiKey, sin contraseña y sin esperar el mail. Registrá una en cada dispositivo que uses seguido.
          </p>

          {passkeyMsg === 'added' && <div class="alert alert-ok">Passkey agregada.</div>}
          {passkeyMsg === 'removed' && <div class="alert alert-ok">Passkey eliminada.</div>}
          <div id="passkey-msg" class="alert alert-error" style="display:none;"></div>

          {userPasskeys.length === 0 ? (
            <p class="meta" style="font-style: italic;">No tenés passkeys registradas.</p>
          ) : (
            <ul style="list-style: none; padding: 0; margin: 0 0 16px;">
              {userPasskeys.map((pk) => (
                <li style="display: flex; align-items: center; justify-content: space-between; gap: 16px; padding: 12px 0; border-bottom: 1px solid var(--rule);">
                  <div>
                    <div style="font-family: var(--font-serif); font-size: 16px; font-weight: 500;">{pk.deviceName ?? 'passkey'}</div>
                    <div class="meta">
                      Agregada {relativeTime(pk.createdAt)}
                      {pk.lastUsedAt && <> · usada {relativeTime(pk.lastUsedAt)}</>}
                    </div>
                  </div>
                  <form method="post" action="/api/auth/passkey/delete">
                    <input type="hidden" name="passkeyId" value={pk.id} />
                    <button type="submit" class="btn btn-ghost">Borrar</button>
                  </form>
                </li>
              ))}
            </ul>
          )}

          <div style="display: flex; align-items: flex-end; gap: 8px;">
            <label style="flex: 1;">
              <span class="kicker kicker--muted" style="display: block; margin-bottom: 6px;">Nombre del dispositivo</span>
              <input type="text" id="passkey-name" placeholder="ej: mi iphone" maxlength="60" />
            </label>
            <button type="button" id="passkey-add" class="btn">+ Agregar passkey</button>
          </div>
        </details>

        <script>
          import { startRegistration, browserSupportsWebAuthn } from '@simplewebauthn/browser';

          const btn = document.getElementById('passkey-add');
          const input = document.getElementById('passkey-name') as HTMLInputElement | null;
          const msg = document.getElementById('passkey-msg');

          function show(text: string, ok = false) {
            if (!msg) return;
            msg.textContent = text;
            msg.className = ok ? 'alert alert-ok' : 'alert alert-error';
            msg.style.display = 'block';
          }

          if (btn) {
            if (!browserSupportsWebAuthn()) {
              btn.setAttribute('disabled', 'true');
              btn.style.opacity = '0.5';
              btn.title = 'tu navegador no soporta passkeys';
            }
            btn.addEventListener('click', async () => {
              try {
                const optsRes = await fetch('/api/auth/passkey/register/start', { method: 'POST' });
                if (!optsRes.ok) throw new Error('no se pudo iniciar');
                const options = await optsRes.json();
                const response = await startRegistration({ optionsJSON: options });
                const finishRes = await fetch('/api/auth/passkey/register/finish', {
                  method: 'POST',
                  headers: { 'content-type': 'application/json' },
                  body: JSON.stringify({ response, deviceName: input?.value ?? null }),
                });
                if (!finishRes.ok) {
                  const data = await finishRes.json().catch(() => ({}));
                  throw new Error(data.error ?? 'no se pudo guardar');
                }
                window.location.href = window.location.pathname + '?passkey=added';
              } catch (err: any) {
                if (err?.name === 'NotAllowedError') return;
                console.error(err);
                show('Error: ' + (err?.message ?? 'desconocido'));
              }
            });
          }
        </script>
      </>
    )}

    <header class="replies-h" style="margin-top: 48px;">
      <h3>Hilos abiertos</h3>
    </header>

    {threads.length === 0 ? (
      <p class="meta" style="padding: 32px 0;">Todavía no abrió hilos.</p>
    ) : (
      <div class="feed">
        {threads.map((t) => (
          <article class="feed-item">
            <div class="feed-item__head" style="grid-column: 1 / -1;">
              <span class="kicker"><a href={`/tema/${t.topicSlug}`} style="color: inherit;">{t.topicName}</a></span>
              <span class="meta" style="color: var(--ink-3);">{t.countryName}</span>
              <span class="meta" style="margin-left: auto;">{relativeTime(t.lastActivityAt)}</span>
            </div>
            <h2 class="feed-item__title" style="font-size: 22px;">
              <a href={`/h/${t.id}`}>{t.title}</a>
            </h2>
          </article>
        ))}
      </div>
    )}
  </article>
</BaseLayout>
