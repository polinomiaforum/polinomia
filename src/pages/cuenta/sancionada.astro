---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { db, schema } from '~/db';
import { and, desc, eq, gte } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/login');

const awaiting = Astro.locals.awaitingReformulation ?? [];
const suspendedUntil = user.suspendedUntil;
const expelled = !!user.expelledAt;

const latestSanctions = await db.select()
  .from(schema.sanctions)
  .where(and(
    eq(schema.sanctions.userId, user.id),
    gte(schema.sanctions.appliedAt, new Date(Date.now() - 180 * 86400_000)),
  ))
  .orderBy(desc(schema.sanctions.appliedAt))
  .limit(10);
---
<BaseLayout title="Cuenta sancionada">
  <article class="thread page-anim">
    <div class="thread__kicker">
      <span class="kicker">Estado de cuenta</span>
    </div>
    <h1 class="thread__title">Tu cuenta tiene restricciones</h1>

    {expelled && (
      <div class="alert alert-error">
        Tu cuenta fue expulsada. No podés volver a participar. Si creés que es un error,
        escribí a <a href="mailto:moderacion@polinomia.org" style="color: var(--accent);">moderacion@polinomia.org</a>.
      </div>
    )}

    {!expelled && suspendedUntil && suspendedUntil.getTime() > Date.now() && (
      <div class="alert alert-error">
        Cuenta suspendida hasta <b>{suspendedUntil.toLocaleString('es')}</b>. Durante la suspensión no podés abrir hilos ni responder.
      </div>
    )}

    {awaiting.length > 0 && (
      <div class="alert">
        <b>Tenés posts pendientes de reformular:</b>
        <ul style="margin: 8px 0 0 18px; padding: 0;">
          {awaiting.map((p) => (
            <li>
              <a href={`/h/editar/${p.id}`} style="color: var(--accent);">→ Editar post #{p.id}</a>
              {p.dueAt && <span class="meta" style="margin-left: 8px;">(vence {p.dueAt.toLocaleString('es')})</span>}
            </li>
          ))}
        </ul>
        <p class="meta" style="margin-top: 12px;">
          Mientras no los reformules, no podés escribir nuevos posts.
        </p>
      </div>
    )}

    <header class="replies-h" style="margin-top: 48px;">
      <h3>Historial reciente</h3>
    </header>

    {latestSanctions.length === 0 ? (
      <p class="meta" style="padding: 32px 0;">No hay sanciones recientes.</p>
    ) : (
      <ul style="list-style: none; padding: 0; margin: 0;">
        {latestSanctions.map((s) => (
          <li style="padding: 14px 0; border-bottom: 1px solid var(--rule);">
            <div style="display: flex; align-items: center; gap: 12px; flex-wrap: wrap;">
              <span class="reply__tag reply__tag--reformular">{s.type}</span>
              {s.ruleNumber && <span class="reply__tag">Regla {s.ruleNumber}</span>}
              <span class="meta">{s.appliedAt.toLocaleString('es')}</span>
            </div>
            <p style="margin: 8px 0 0; font-family: var(--font-serif); font-size: 15px;">{s.reason}</p>
          </li>
        ))}
      </ul>
    )}

    <p class="meta" style="margin-top: 32px;">
      <a href="/reglas" style="color: var(--accent);">→ Ver código de conducta</a>
    </p>
  </article>
</BaseLayout>
