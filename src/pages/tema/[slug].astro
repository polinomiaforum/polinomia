---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Byline from '~/components/Byline.astro';
import { db, schema } from '~/db';
import { and, desc, eq, sql } from 'drizzle-orm';
import { relativeTime } from '~/lib/text';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/');

const [topic] = await db.select().from(schema.topics).where(eq(schema.topics.slug, slug)).limit(1);
if (!topic) return new Response('Tema no encontrado', { status: 404 });

const countryFilter = Astro.url.searchParams.get('pais');

const threads = await db.select({
  id: schema.threads.id,
  title: schema.threads.title,
  createdAt: schema.threads.createdAt,
  lastActivityAt: schema.threads.lastActivityAt,
  countrySlug: schema.countries.slug,
  countryName: schema.countries.name,
  authorUsername: schema.users.username,
  authorDeclaredView: schema.users.declaredView,
  authorAvatarUrl: schema.users.avatarUrl,
})
  .from(schema.threads)
  .innerJoin(schema.countries, eq(schema.countries.id, schema.threads.countryId))
  .innerJoin(schema.users, eq(schema.users.id, schema.threads.authorId))
  .where(and(
    eq(schema.threads.topicId, topic.id),
    countryFilter ? eq(schema.countries.slug, countryFilter) : undefined,
  ))
  .orderBy(desc(schema.threads.lastActivityAt));

const countries = await db.selectDistinct({
  slug: schema.countries.slug,
  name: schema.countries.name,
})
  .from(schema.threads)
  .innerJoin(schema.countries, eq(schema.countries.id, schema.threads.countryId))
  .where(eq(schema.threads.topicId, topic.id))
  .orderBy(schema.countries.name);
---
<BaseLayout title={topic.name}>
  <div style="padding: 24px 0 12px;">
    <span class="kicker"><a href="/" style="color: inherit;">Foro</a> · {topic.name}</span>
  </div>

  <h1 style="font-family: var(--font-serif); font-weight: 400; font-size: clamp(40px, 5vw, 56px); line-height: 1.05; margin: 8px 0 12px; letter-spacing: -0.018em;">
    {topic.name}
  </h1>
  {topic.description && (
    <p style="font-family: var(--font-serif); font-size: 20px; line-height: 1.5; color: var(--ink-2); margin: 0 0 24px; max-width: 60ch;">
      {topic.description}
    </p>
  )}

  {countries.length > 0 && (
    <div class="substrip">
      <div class="substrip__cats">
        <a href={`/tema/${topic.slug}`} class:list={[!countryFilter && 'is-active']}>Todos los países</a>
        {countries.map((c) => (
          <a href={`/tema/${topic.slug}?pais=${c.slug}`} class:list={[countryFilter === c.slug && 'is-active']}>{c.name}</a>
        ))}
      </div>
    </div>
  )}

  {threads.length === 0 ? (
    <p class="meta" style="padding: 60px 0; text-align: center;">
      Todavía no hay hilos. <a href="/h/nuevo" style="color: var(--accent);">Abrí el primero →</a>
    </p>
  ) : (
    <div class="feed">
      {threads.map((t) => (
        <article class="feed-item">
          <div class="feed-item__head" style="grid-column: 1 / -1;">
            <span class="meta" style="color: var(--ink-3);">{t.countryName}</span>
            <span class="meta" style="margin-left: auto;">{relativeTime(t.lastActivityAt)}</span>
          </div>
          <h2 class="feed-item__title">
            <a href={`/h/${t.id}`}>{t.title}</a>
          </h2>
          <div class="feed-item__footer">
            <Byline username={t.authorUsername} declaredView={t.authorDeclaredView} avatarUrl={t.authorAvatarUrl} />
          </div>
        </article>
      ))}
    </div>
  )}

  <div style="margin-top: 36px; padding-bottom: 60px;">
    <a href={`/h/nuevo?tema=${topic.slug}`} class="btn">Abrir un hilo en {topic.name}</a>
  </div>
</BaseLayout>
